##############################################################################
# Jitsi Meet + Recording + Whiteboard - Environment Configuration
#
# 1. Copy this file:   cp .env.jitsi.example .env.jitsi
# 2. Fill in every value marked  ← CHANGE
# 3. Paste entire contents into Dokploy → Jitsi-Web-app → Environment tab
#
##############################################################################

# ─── Jitsi Domain ────────────────────────────────────────────────────────────
# The public domain where Jitsi will be accessible (set in Dokploy Domains tab)
JITSI_DOMAIN=meet.yourdomain.com               # ← CHANGE  (e.g. meet.edunura.com)

# ─── XMPP Internal Domain ────────────────────────────────────────────────────
# Internal domain used between containers — leave as-is
JITSI_XMPP_DOMAIN=meet.jitsi

# ─── Logging ─────────────────────────────────────────────────────────────────
JITSI_LOG_LEVEL=info                           # debug | info | warn | error

# ─── Timezone ────────────────────────────────────────────────────────────────
JITSI_TZ=Asia/Kolkata                          # ← CHANGE to your timezone

# ─── JWT Authentication (for LMS role enforcement) ───────────────────────────
# APP_ID  = any short identifier you choose (used as the JWT "audience")
# APP_SECRET = a long random string YOU generate right now — never share it
#              Copy this EXACT same value into your LMS backend .env as JITSI_APP_SECRET
JITSI_APP_ID=edunura_lms
JITSI_APP_SECRET=changeme_use_strong_secret    # ← CHANGE: generate with openssl rand -hex 32

# ─── Jicofo (Conference Focus) ───────────────────────────────────────────────
JICOFO_COMPONENT_SECRET=jicofoauthsecret       # ← CHANGE: Strong password
JICOFO_AUTH_PASSWORD=focusauthpass             # ← CHANGE: Strong password

# ─── JVB (Video Bridge) ──────────────────────────────────────────────────────
JVB_AUTH_USER=jvb
JVB_AUTH_PASSWORD=jvbauthpass                  # ← CHANGE: Strong password
JVB_PORT=10000                                 # UDP port — must be open in firewall
JVB_PUBLIC_IP=YOUR_SERVER_PUBLIC_IP            # ← CHANGE REQUIRED
                                               #   Get it: ssh into server → curl ifconfig.me
                                               #   Example: 168.231.120.34

# ─── Jibri (Recording Service) ───────────────────────────────────────────────
JIBRI_XMPP_USER=jibri
JIBRI_XMPP_PASSWORD=jibriauthpass              # ← CHANGE: Strong password
JIBRI_RECORDER_USER=recorder
JIBRI_RECORDER_PASSWORD=recorderpass           # ← CHANGE: Strong password

# ─── PostgreSQL (for Jitsi config storage) ───────────────────────────────────
JITSI_DB_NAME=jitsi_config
JITSI_DB_USER=jitsi
JITSI_DB_PASSWORD=jitsi123                     # ← CHANGE: Strong password

# ─── Etherpad (Whiteboard — file-based storage, no extra DB needed) ──────────
ETHERPAD_ADMIN_PASSWORD=etherpadpass           # ← CHANGE: Strong password

##############################################################################
# GENERATE STRONG PASSWORDS (run on your server or local machine):
#
#   PowerShell (Windows):
#     -join ((65..90)+(97..122)+(48..57) | Get-Random -Count 32 | % {[char]$_})
#
#   Linux/Mac (OpenSSL):
#     openssl rand -base64 32
#
#   Node.js:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
##############################################################################
#
# WHAT EACH VARIABLE DOES:
#
#   JITSI_DOMAIN              Public URL (must match domain in Dokploy Domains tab)
#   JITSI_XMPP_DOMAIN         Internal hostname for container communication (keep meet.jitsi)
#   JICOFO_COMPONENT_SECRET   Prosody ↔ Jicofo shared secret (must match on both sides)
#   JICOFO_AUTH_PASSWORD      Jicofo login password on Prosody auth domain
#   JVB_PUBLIC_IP             Your server's public IP — without this video won't work externally
#   JIBRI_XMPP_PASSWORD       Jibri XMPP login password (for the jibri user on Prosody)
#   JIBRI_RECORDER_USER       Silent recorder user Jibri uses to join and record meetings
#   JIBRI_RECORDER_PASSWORD   Password for the recorder user above
#
##############################################################################
