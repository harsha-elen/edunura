# Backend Environment Configuration - JITSI INTEGRATION
# ========================================================
# Copy this file to backend/.env.docker or backend/.env
# Update ONLY the Jitsi-related sections with your values

# ============================================
# JITSI CONFIGURATION (NEW - Add this section)
# ============================================

# Platform choice: 'zoom' or 'jitsi' or 'public_jitsi'
MEETING_PLATFORM=jitsi

# Self-Hosted Jitsi Configuration (RECOMMENDED FOR SECURITY)
# =========================================================
# Use this if you deployed docker-compose.jitsi.yml in Dokploy

# Your Jitsi domain (where you deployed the Docker Compose)
# Example: https://jitsi.yourdomain.com
JITSI_DOMAIN=https://jitsi.yourdomain.com

# Optional: JWT Authentication (for role-based enforcement)
# Leave empty if not using JWT
JITSI_APP_ID=edunura_lms

# Secret key for JWT signing (KEEP SECRET!)
# Must match JITSI_APP_SECRET in Dokploy .env.jitsi file
JITSI_APP_SECRET=your_very_long_secret_key_here_change_this

# Recording enabled (if using self-hosted with Jibri)
JITSI_RECORDING_ENABLED=true

# ============================================
# PUBLIC JITSI CONFIGURATION (For testing only)
# =========================================================
# ONLY use this if you don't have self-hosted Jitsi deployed yet
# WARNING: No role-based enforcement! Students can see all buttons.

# PUBLIC_JITSI_DOMAIN=https://meet.jit.si
# MEETING_PLATFORM=public_jitsi


# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=edunura_user
DB_PASSWORD=your_secure_password_here
DB_NAME=edunura_lms
DB_DIALECT=postgres

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ============================================
# PORT & SERVER
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# AWS S3 (Optional)
# ============================================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your_bucket_name
AWS_S3_URL=https://s3.amazonaws.com/your_bucket_name

# ============================================
# UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600  # 100MB in bytes

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@edunura.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ============================================
# SESSION & COOKIES
# ============================================
SESSION_SECRET=your_session_secret_here
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict

# ============================================
# CORS CONFIGURATION
# ============================================
# List your frontend domains here
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com,https://app.yourdomain.com,https://admin.yourdomain.com

# ============================================
# ADMIN CREDENTIALS (CHANGE THESE!)
# ============================================
ADMIN_EMAIL=admin@edunura.com
ADMIN_PASSWORD=change_me_to_strong_password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# ============================================
# ZOOM CONFIGURATION (Legacy - if still using)
# ============================================
# ZOOM_APP_ID=your_zoom_app_id
# ZOOM_APP_SECRET=your_zoom_app_secret
# ZOOM_ACCOUNT_ID=your_zoom_account_id

# ============================================
# SYSTEM CONFIGURATION
# ============================================
TIMEZONE=UTC
CURRENCY=USD
LANGUAGE=en

# ============================================
# SECURITY
# ============================================
# Rate limiting requests per minute
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Encryption key for sensitive data
ENCRYPTION_KEY=your_encryption_key_here_minimum_32_characters

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_LIVE_CLASSES=true
ENABLE_RECORDINGS=true
ENABLE_WHITEBOARD=true
ENABLE_SCREEN_SHARE=true
ENABLE_STUDENT_FORUM=true
ENABLE_CERTIFICATIONS=true

# ============================================
# INTEGRATION NOTES
# ============================================
#
# 1. JITSI DEPLOYMENT STATUS
#    If you received a docker-compose.jitsi.yml file:
#    - Deploy it in Dokploy
#    - Copy the JITSI_DOMAIN value from your Dokploy domain settings
#    - Paste here in JITSI_DOMAIN variable
#    - Update JITSI_APP_ID and JITSI_APP_SECRET to match Dokploy .env.jitsi
#
# 2. ROLE-BASED ENFORCEMENT
#    Backend implementation already supports:
#    - Teachers/Admins join as MODERATORS (can mute all, record, whiteboard)
#    - Students join as PARTICIPANTS (limited toolbar buttons)
#    
#    This enforcement happens at TWO levels:
#    a) JWT token (server-side, if using self-hosted Jitsi)
#    b) Toolbar UI (client-side, filtered based on role)
#
# 3. RECORDING
#    - Enabled by default when using docker-compose.jitsi.yml
#    - Jibri service captures meetings automatically
#    - Recordings stored in /recordings volume in Dokploy
#    - Currently not linked to LMS database (Phase 2)
#
# 4. WHITEBOARD (ETHERPAD)
#    - Included in docker-compose.jitsi.yml
#    - Accessible from Jitsi meeting UI
#    - Teachers can enable in live class settings
#
# 5. PUBLIC JITSI (Testing only)
#    - If you use https://meet.jit.si instead of self-hosted
#    - Role enforcement is client-side only (NOT secure)
#    - Students can access all buttons/features via browser dev tools
#    - NOT RECOMMENDED for production
#
# 6. LIVE CLASS FLOW
#    Teacher creates class → Backend generates JWT → Jitsi embedded
#    → Teacher joins as moderator → Students join as participants
#    → Meeting recorded → Left in Dokploy /recordings volume
#
# ============================================
# MIGRATION CHECKLIST
# ============================================
# ☐ Fill in DATABASE section with your DB credentials
# ☐ Fill in JWT_SECRET (use strong random value)
# ☐ Fill in ENCRYPTION_KEY (use strong random value)
# ☐ Fill in JITSI_DOMAIN (after deploying docker-compose.jitsi.yml)
# ☐ Fill in JITSI_APP_ID and JITSI_APP_SECRET (match Dokploy values)
# ☐ Fill in ADMIN credentials
# ☐ Fill in CORS_ORIGINS with your frontend domains
# ☐ Test: Teacher creates live class
# ☐ Test: Student joins and sees limited toolbar
# ☐ Test: Teacher mutes all students
# ☐ Test: Recording appears in Dokploy /recordings volume
# ☐ Test: Whiteboard/Etherpad opens in meeting
#
# ============================================
